# ============================
# LingoGenBot - Environment Config
# ============================

# Telegram Bot
BOT_TOKEN=your-telegram-bot-token-here
MONITOR_CHANNEL_ID=-100123456789

# Backend
BACKEND_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lingogenbot
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lingogenbot

# SQLite (local dev without Docker)
# DATABASE_URL=sqlite+aiosqlite:///./lingogenbot.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Matchmaking settings
MATCH_TIMEOUT_SECONDS=120
SESSION_DURATION_SECONDS=300
SEARCH_UPDATE_INTERVAL=15

# Debug
DEBUG=false
